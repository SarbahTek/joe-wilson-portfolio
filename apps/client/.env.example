# Backend API base URL (without /v1 suffix). Used by the Vite dev proxy and production builds.
VITE_API_BASE_URL=https://joe-wilson-api-production.up.railway.app

# Local dev: API calls use /v1 on localhost and are proxied to VITE_API_BASE_URL (no CORS issues).
# Restart `npm run dev` after changing this file.
